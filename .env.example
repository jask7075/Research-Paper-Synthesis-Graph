# Copy to .env and fill in. .env is git-ignored.

# --- LLM (extraction batch + judge/synthesis) ---
ANTHROPIC_API_KEY=

# --- Semantic Scholar (higher rate limits with a key; optional) ---
S2_API_KEY=

# --- Services (only needed for real PDF parsing) ---
# GROBID running locally: `make grobid` starts it on :8070
RPSG_GROBID_URL=http://localhost:8070

# --- Optional: pgvector (Phase-1.5). Leave unset to use the local FAISS store. ---
# RPSG_PG_DSN=postgresql://rpsg:rpsg@localhost:5432/rpsg